---
import Icon from '../Icon/Icon.astro';
import { siteConfig } from '../../config/site.ts';

const socials = [
  { href: `mailto:${siteConfig.email}`, label: 'Email', icon: 'Envelope', external: false },
  { href: siteConfig.social.github, label: 'GitHub', icon: 'GithubLogo', external: true },
  { href: siteConfig.social.linkedin, label: 'LinkedIn', icon: 'LinkedinLogo', external: true },
  { href: siteConfig.social.bluesky, label: 'Bluesky', icon: 'Butterfly', external: true },
  { href: siteConfig.social.twitter, label: 'X', icon: 'XLogo', external: true },
  { href: siteConfig.social.instagram, label: 'Instagram', icon: 'InstagramLogo', external: true },
] as const;
---

<aside class="side-nav" aria-label="Primary">
  <div class="side-nav-inner">
    <a href="/" class="side-brand">
      <span class="side-brand-mark" aria-hidden="true">
        <img src="/images/about/esheadshot.jpg" alt="" width="40" height="40" />
      </span>
      <span class="side-brand-text">
        <span class="side-brand-name">shupp.dev</span>
        <span class="side-brand-sub">Fractional Founder</span>
      </span>
    </a>

    <div class="side-nav-divider" aria-hidden="true"></div>

    <nav class="side-nav-menu">
      <ul class="side-nav-list">
        <li class="side-nav-item">
          <a href="/" class="side-nav-link">
            <span class="side-nav-icon">
              <Icon name="House" size={20} weight="duotone" liquid={true} />
            </span>
            <span class="side-nav-text">Home</span>
          </a>
        </li>
        <li class="side-nav-item">
          <a href="/about" class="side-nav-link">
            <span class="side-nav-icon">
              <Icon name="User" size={20} weight="duotone" liquid={true} />
            </span>
            <span class="side-nav-text">About</span>
          </a>
        </li>
        <li class="side-nav-item">
          <a href="/portfolio" class="side-nav-link">
            <span class="side-nav-icon">
              <Icon name="Briefcase" size={20} weight="duotone" liquid={true} />
            </span>
            <span class="side-nav-text">Portfolio</span>
          </a>
        </li>
        <li class="side-nav-item">
          <a href="/galaxy" class="side-nav-link">
            <span class="side-nav-icon">
              <Icon name="Planet" size={20} weight="duotone" liquid={true} />
            </span>
            <span class="side-nav-text">Galaxy</span>
          </a>
        </li>
        <li class="side-nav-item">
          <a href="/press" class="side-nav-link">
            <span class="side-nav-icon">
              <Icon name="Newspaper" size={20} weight="duotone" liquid={true} />
            </span>
            <span class="side-nav-text">Press</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="side-nav-socials" aria-label="Personal links">
      <span class="side-nav-section-label">Personal</span>
      <div class="side-nav-socials-grid">
        {socials.map((s) => (
          <a
            href={s.href}
            class="side-nav-social"
            aria-label={s.label}
            title={s.label}
            {...(s.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <Icon name={s.icon} size={18} weight="duotone" />
          </a>
        ))}
      </div>
    </div>

    <div class="side-nav-footer">
      <span class="side-nav-footnote">© {new Date().getFullYear()}</span>
      <button id="side-nav-theme-toggle" class="side-theme-toggle" aria-label="Toggle dark mode">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="theme-icon-svg">
          <circle class="sun-icon" cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
          <path class="sun-rays" d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path class="moon-icon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</aside>

<button class="side-nav-mobile-toggle" aria-label="Toggle navigation" aria-expanded="false">
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
</button>

<script>
  document.addEventListener('astro:page-load', () => {
    const sideNav = document.querySelector('.side-nav');
    const mobileToggle = document.querySelector('.side-nav-mobile-toggle');
    const themeToggle = document.getElementById('side-nav-theme-toggle');
    const html = document.documentElement;

    if (sideNav && mobileToggle) {
      mobileToggle.addEventListener('click', () => {
        const isOpen = sideNav.classList.toggle('mobile-open');
        mobileToggle.classList.toggle('active', isOpen);
        mobileToggle.setAttribute('aria-expanded', String(isOpen));
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });

      sideNav.querySelectorAll('.side-nav-link').forEach((link) => {
        link.addEventListener('click', () => {
          sideNav.classList.remove('mobile-open');
          mobileToggle.classList.remove('active');
          mobileToggle.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        });
      });
    }

    const syncThemeIcon = () => {
      if (themeToggle) {
        themeToggle.classList.toggle('dark-mode', html.classList.contains('dark'));
      }
    };

    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        html.classList.toggle('dark');
        const isDark = html.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncThemeIcon();
        window.dispatchEvent(new CustomEvent('themechange', {
          detail: { isDarkMode: isDark }
        }));
      });
    }

    syncThemeIcon();

    // Mark current page link as active
    const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('.side-nav-link').forEach((link) => {
      const href = link.getAttribute('href');
      const normalized = href === '/' ? '/' : href?.replace(/\/$/, '');
      if (normalized === currentPath) {
        link.classList.add('active');
      }
    });
  });
</script>

<style>
  .side-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 240px;
    height: 100vh;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 249, 246, 0.92));
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-right: 1px solid rgba(121, 148, 150, 0.15);
    box-shadow: 1px 0 30px rgba(20, 8, 14, 0.04);
    z-index: 100;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    overflow-y: auto;
    overflow-x: hidden;
  }

  html.dark .side-nav {
    background:
      linear-gradient(180deg, rgba(28, 28, 35, 0.92), rgba(35, 35, 43, 0.92));
    border-right-color: rgba(233, 235, 158, 0.08);
    box-shadow: 1px 0 30px rgba(0, 0, 0, 0.25);
  }

  .side-nav-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem 1rem;
    gap: 1.25rem;
  }

  .side-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.5rem;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.25s ease;
  }

  .side-brand:hover {
    background-color: rgba(121, 148, 150, 0.06);
  }

  html.dark .side-brand:hover {
    background-color: rgba(233, 235, 158, 0.05);
  }

  .side-brand-mark {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-accent);
    box-shadow: 0 2px 8px rgba(20, 8, 14, 0.08);
    display: block;
  }

  .side-brand-mark img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .side-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    min-width: 0;
  }

  .side-brand-name {
    font-family: var(--font-main-header);
    font-size: 1.15rem;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    color: var(--color-dark);
  }

  html.dark .side-brand-name {
    color: #f3f4f6;
  }

  .side-brand-sub {
    font-family: var(--font-secondary-header);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-tertiary);
    margin-top: 0.2rem;
  }

  html.dark .side-brand-sub {
    color: var(--color-accent);
  }

  .side-nav-divider {
    height: 1px;
    margin: 0 0.5rem;
    background: linear-gradient(
      to right,
      transparent,
      rgba(121, 148, 150, 0.25),
      transparent
    );
  }

  html.dark .side-nav-divider {
    background: linear-gradient(
      to right,
      transparent,
      rgba(233, 235, 158, 0.18),
      transparent
    );
  }

  .side-nav-menu {
    flex: 1;
  }

  .side-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .side-nav-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.65rem 0.85rem;
    color: var(--color-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    font-family: var(--font-secondary-header);
    letter-spacing: 0.01em;
    border-radius: 10px;
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    position: relative;
  }

  html.dark .side-nav-link {
    color: #c5c5d2;
  }

  .side-nav-link:hover {
    background-color: rgba(121, 148, 150, 0.09);
    color: var(--color-dark);
  }

  html.dark .side-nav-link:hover {
    background-color: rgba(233, 235, 158, 0.06);
    color: #f3f4f6;
  }

  .side-nav-link.active {
    background: linear-gradient(
      135deg,
      rgba(121, 148, 150, 0.16),
      rgba(172, 193, 150, 0.12)
    );
    color: var(--color-dark);
    box-shadow: inset 0 0 0 1px rgba(121, 148, 150, 0.2);
  }

  html.dark .side-nav-link.active {
    background: linear-gradient(
      135deg,
      rgba(233, 235, 158, 0.14),
      rgba(172, 193, 150, 0.08)
    );
    color: #f3f4f6;
    box-shadow: inset 0 0 0 1px rgba(233, 235, 158, 0.18);
  }

  .side-nav-link.active::before {
    content: '';
    position: absolute;
    left: -1rem;
    top: 28%;
    bottom: 28%;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: linear-gradient(to bottom, var(--color-tertiary), var(--color-accent));
    box-shadow: 0 0 12px rgba(172, 193, 150, 0.5);
  }

  .side-nav-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: var(--color-tertiary);
    transition: transform 0.3s ease, color 0.25s ease;
  }

  .side-nav-link:hover .side-nav-icon {
    transform: translateX(2px);
    color: var(--color-dark);
  }

  html.dark .side-nav-link:hover .side-nav-icon {
    color: var(--color-light);
  }

  .side-nav-link.active .side-nav-icon {
    color: var(--color-dark);
  }

  html.dark .side-nav-link.active .side-nav-icon {
    color: var(--color-light);
  }

  html.dark .side-nav-icon {
    filter: brightness(1.15);
  }

  .side-nav-socials {
    padding: 0 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .side-nav-section-label {
    font-family: var(--font-secondary-header);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-tertiary);
    opacity: 0.75;
  }

  html.dark .side-nav-section-label {
    color: var(--color-accent);
    opacity: 0.7;
  }

  .side-nav-socials-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-start;
  }

  .side-nav-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    color: var(--color-tertiary);
    background-color: transparent;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .side-nav-social:hover {
    background-color: rgba(121, 148, 150, 0.12);
    color: var(--color-dark);
    transform: translateY(-1px);
  }

  html.dark .side-nav-social {
    color: var(--color-accent);
  }

  html.dark .side-nav-social:hover {
    background-color: rgba(233, 235, 158, 0.1);
    color: #f3f4f6;
  }

  .side-nav-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.5rem 0;
    border-top: 1px solid rgba(121, 148, 150, 0.12);
    margin-top: 0.25rem;
  }

  html.dark .side-nav-footer {
    border-top-color: rgba(233, 235, 158, 0.08);
  }

  .side-nav-footnote {
    font-family: var(--font-secondary-header);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-tertiary);
    opacity: 0.7;
  }

  html.dark .side-nav-footnote {
    color: var(--color-accent);
  }

  .side-theme-toggle {
    background: transparent;
    border: 1.5px solid rgba(73, 71, 91, 0.4);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  .side-theme-toggle:hover {
    background-color: rgba(121, 148, 150, 0.1);
    transform: scale(1.05);
  }

  html.dark .side-theme-toggle {
    border-color: var(--color-light);
    color: var(--color-light);
  }

  html.dark .side-theme-toggle:hover {
    background-color: rgba(233, 235, 158, 0.1);
  }

  .theme-icon-svg {
    width: 20px;
    height: 20px;
  }

  .side-theme-toggle .moon-icon {
    display: none;
  }

  .side-theme-toggle .sun-icon,
  .side-theme-toggle .sun-rays {
    display: block;
  }

  .side-theme-toggle.dark-mode .sun-icon,
  .side-theme-toggle.dark-mode .sun-rays {
    display: none;
  }

  .side-theme-toggle.dark-mode .moon-icon {
    display: block;
  }

  /* Mobile toggle button - hidden on desktop */
  .side-nav-mobile-toggle {
    display: none;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 110;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(121, 148, 150, 0.2);
    border-radius: 8px;
    width: 44px;
    height: 44px;
    flex-direction: column;
    justify-content: space-around;
    padding: 12px 10px;
    cursor: pointer;
    box-shadow: 0 2px 10px rgba(20, 8, 14, 0.08);
  }

  html.dark .side-nav-mobile-toggle {
    background: rgba(35, 35, 43, 0.95);
    border-color: rgba(233, 235, 158, 0.2);
  }

  .side-nav-mobile-toggle .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-secondary);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  html.dark .side-nav-mobile-toggle .hamburger-line {
    background-color: #c5c5d2;
  }

  .side-nav-mobile-toggle.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .side-nav-mobile-toggle.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .side-nav-mobile-toggle.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Mobile: side nav slides in from the left */
  @media (max-width: 768px) {
    .side-nav {
      transform: translateX(-100%);
      width: 260px;
    }

    .side-nav.mobile-open {
      transform: translateX(0);
    }

    .side-nav-mobile-toggle {
      display: flex;
    }
  }
</style>
