  }
];

const education = [
  {
    school: "George Mason University",
    degree: "MS, Technology Management",
    date: "2014 - 2016",
    logo: "/images/education/gmu-logo.png"
  },
  {
    school: "Longwood University",
    degree: "BA, English Creative Writing",
    date: "2009 - 2013",
    logo: "/images/education/longwood-logo.png"
  }
];

const certifications = [
  "UX Master Certificate (UXMC) - Nielsen Norman Group",
  "Product Management Certificate - Product School",
  "SAFe 4 Practitioner",
  "ITIL v4 Foundation",
  "FedRAMP Moderate Product Team",
  "TryHackMe Pre-Security Certificate"
];
---

<Layout title="Resume - Erikk Shupp" description="Professional resume of Erikk Shupp - Fractional CTO & Product Engineering Lead">
  <div class="resume-container">
    <a href="/about" class="back-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to About
    </a>

    <header class="resume-header">
      <div class="profile-section">
        <div class="profile-photo">
          <img src="/images/about/esheadshot.jpg" alt="Erikk Shupp" />
        </div>
        <div class="profile-info">
          <h1>Erikk Shupp</h1>
          <p class="headline">Fractional CTO · Product Engineering Lead · Founder</p>
          <p class="location">Arlington, Virginia · Remote/Hybrid</p>
          <div class="profile-actions">
            <a href={`mailto:erikk@shupp.dev`} class="btn btn-primary">Contact</a>
            <a href="/portfolio" class="btn btn-secondary">Portfolio</a>
          </div>
        </div>
      </div>
    </header>

    <main class="resume-content">
      <section class="experience-section">
        <h2>Experience</h2>
        
        {experiences.map((job) => (
          <div class="experience-item">
            <div class="company-logo">
              {job.logo ? (
                <img src={job.logo} alt={`${job.company} logo`} />
              ) : (
                <div class="logo-placeholder">
                  <span>{job.company.charAt(0)}</span>
                </div>
              )}
            </div>
            
            <div class="experience-details">
              <div class="job-header">
                <h3 class="job-title">{job.title}</h3>
                <p class="company-name">
                  {job.company}
                  <span class="separator">·</span>
                  <span class="employment-type">{job.employmentType}</span>
                </p>
                <p class="date-location">
                  {job.startDate} - {job.endDate || "Present"} · {job.duration}
                  <span class="separator">·</span>
                  {job.location}
                </p>
              </div>
              
              <div class="job-description">
                <p>{job.description}</p>
                
                {job.stack && (
                  <div class="tech-section">
                    <strong>stack:</strong> {job.stack.join(", ")}
                  </div>
                )}
                
                {job.governance && (
                  <div class="tech-section">
                    <strong>governance:</strong> {job.governance.join(", ")}
                  </div>
                )}
                
                {job.aiTooling && (
                  <div class="tech-section">
                    <strong>ai tooling:</strong> {job.aiTooling.join(", ")}
                  </div>
                )}
                
                {job.website && (
                  <a href={`https://${job.website}`} target="_blank" rel="noopener noreferrer" class="website-link">
                    {job.website}
                  </a>
                )}
              </div>
              
              <div class="skills-tags">
                {job.skills.map((skill) => (
                  <span class="skill-tag">{skill}</span>
                ))}
                <span class="more-skills">+{Math.floor(Math.random() * 10 + 3)} skills</span>
              </div>
            </div>
          </div>
        ))}
      </section>

      <section class="education-section">
        <h2>Education</h2>
        {education.map((edu) => (
          <div class="education-item">
            <div class="school-logo">
              {edu.logo ? (
                <img src={edu.logo} alt={`${edu.school} logo`} />
              ) : (
                <div class="logo-placeholder">
                  <span>{edu.school.charAt(0)}</span>
                </div>
              )}
            </div>
            <div class="education-details">
              <h3>{edu.school}</h3>
              <p class="degree">{edu.degree}</p>
              <p class="date">{edu.date}</p>
            </div>
          </div>
        ))}
      </section>

      <section class="certifications-section">
        <h2>Licenses & Certifications</h2>
        <div class="certifications-list">
          {certifications.map((cert) => (
            <div class="certification-item">
              <Icon name="Certificate" size={20} weight="duotone" />
              <span>{cert}</span>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer class="resume-footer">
      <div class="resume-actions">
        <button class="btn btn-primary" onclick="window.print()">
          <Icon name="Printer" size={18} weight="duotone" />
          Print
        </button>
        <a href="/api/resume.pdf" class="btn btn-secondary">
          <Icon name="Download" size={18} weight="duotone" />
          Download PDF
        </a>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .resume-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* Back Link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-light);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-tertiary);
  }

  .back-link svg {
    transition: transform 0.2s ease;
  }

  .back-link:hover svg {
    transform: translateX(-3px);
  }

  html.dark .back-link {
    color: #a5a5b5;
  }

  html.dark .back-link:hover {
    color: var(--color-accent);
  }

  /* Header */
  .resume-header {
    margin-bottom: 2rem;
  }

  .profile-section {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .profile-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 3px solid var(--color-accent);
  }

  .profile-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-info h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
    color: var(--text-color);
  }

  .headline {
    font-size: 1rem;
    color: var(--text-color);
    margin: 0 0 0.35rem;
  }

  .location {
    font-size: 0.9rem;
    color: var(--text-light);
    margin: 0 0 1rem;
  }

  .profile-actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    font-family: var(--font-secondary-header);
  }

  .btn-primary {
    background: var(--color-tertiary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent);
    color: var(--color-dark);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-tertiary);
    border: 2px solid var(--color-tertiary);
  }

  .btn-secondary:hover {
    background: var(--color-tertiary);
    color: white;
    transform: translateY(-2px);
  }

  html.dark .btn-secondary {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  html.dark .btn-secondary:hover {
    background: var(--color-accent);
    color: var(--color-dark);
  }

  /* Content Sections */
  .resume-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-color);
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  /* Experience Items */
  .experience-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(121, 148, 150, 0.1);
  }

  .experience-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .company-logo {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--background-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .company-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .logo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-tertiary), var(--color-accent));
    color: white;
    font-weight: 700;
    font-size: 1.25rem;
  }

  .experience-details {
    flex: 1;
    min-width: 0;
  }

  .job-header {
    margin-bottom: 0.75rem;
  }

  .job-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 0 0 0.25rem;
  }

  .company-name {
    font-size: 0.95rem;
    color: var(--text-color);
    margin: 0 0 0.15rem;
  }

  .separator {
    color: var(--text-light);
    margin: 0 0.35rem;
  }

  .employment-type {
    color: var(--text-light);
  }

  .date-location {
    font-size: 0.85rem;
    color: var(--text-light);
    margin: 0;
  }

  .job-description {
    margin-bottom: 1rem;
  }

  .job-description p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-color);
    margin: 0 0 0.75rem;
  }

  .tech-section {
    font-size: 0.85rem;
    color: var(--text-light);
    margin-bottom: 0.35rem;
    line-height: 1.5;
  }

  .tech-section strong {
    color: var(--color-tertiary);
    font-weight: 600;
  }

  html.dark .tech-section strong {
    color: var(--color-accent);
  }

  .website-link {
    display: inline-block;
    color: var(--color-tertiary);
    font-size: 0.9rem;
    text-decoration: none;
    margin-top: 0.5rem;
  }

  .website-link:hover {
    text-decoration: underline;
  }

  html.dark .website-link {
    color: var(--color-accent);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .skill-tag {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: rgba(121, 148, 150, 0.1);
    border-radius: 4px;
    font-size: 0.8rem;
    color: var(--text-light);
    font-weight: 500;
  }

  html.dark .skill-tag {
    background: rgba(233, 235, 158, 0.1);
    color: #a5a5b5;
  }

  .more-skills {
    font-size: 0.8rem;
    color: var(--color-tertiary);
    font-weight: 500;
  }

  html.dark .more-skills {
    color: var(--color-accent);
  }

  /* Education */
  .education-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .school-logo {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--background-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .school-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .education-details h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 0 0 0.25rem;
  }

  .degree {
    font-size: 0.95rem;
    color: var(--text-color);
    margin: 0 0 0.15rem;
  }

  .date {
    font-size: 0.85rem;
    color: var(--text-light);
    margin: 0;
  }

  /* Certifications */
  .certifications-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .certification-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: rgba(121, 148, 150, 0.05);
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--text-color);
  }

  .certification-item svg {
    color: var(--color-tertiary);
    flex-shrink: 0;
  }

  html.dark .certification-item {
    background: rgba(233, 235, 158, 0.05);
  }

  html.dark .certification-item svg {
    color: var(--color-accent);
  }

  /* Footer */
  .resume-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .resume-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  /* Print Styles */
  @media print {
    .resume-container {
      padding: 0;
      max-width: 100%;
    }

    .back-link,
    .resume-footer {
      display: none;
    }

    .profile-actions {
      display: none;
    }
  }

  /* Responsive */
  @media (max-width: 640px) {
    .resume-container {
      padding: 1.5rem 1rem;
    }

    .profile-section {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .profile-photo {
      width: 100px;
      height: 100px;
    }

    .profile-info h1 {
      font-size: 1.5rem;
    }

    .profile-actions {
      justify-content: center;
    }

    .experience-item {
      gap: 0.75rem;
    }

    .company-logo {
      width: 48px;
      height: 48px;
    }

    .education-item {
      gap: 0.75rem;
    }

    .school-logo {
      width: 48px;
      height: 48px;
    }
  }
</style>
