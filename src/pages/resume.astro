    stack: ["Next.js", "Prisma", "AWS GovCloud + Auth + Storage + Monitoring (Cognito, S3, PostGres, ECS, Queue, etc)"],
    aiTooling: ["Cursor", "Claude Code", "Opencode", "Warp Terminal", "GovCloud AWS Bedrock", "Anthropic SDK"],
    governance: ["FedRAMP Moderate"],
    skills: ["Software Product Management", "Product Operations"],
    isCurrent: true
  },
  {
    company: "Thoughtful App Co.",
    title: "Founder",
    employmentType: "Self-employed",
    startDate: "Jan 2026",
    duration: "5 mos",
    location: "United States · Remote",
    description: "One agentic-fueled person doing growth, marketing, executive, development and design in his free time to developer local-first, human-first web apps that help people. Providing open-source context libraries to help people prompt llms better.",
    stack: ["Rust + WASM", "Solid.js", "Cloudflare (R2,D1,KV, Queue, Workers)", "taco-sync"],
    aiTooling: ["Warp → Opencode (custom agents) → Fireworks.AI"],
    skills: ["Digital Strategy", "Product Operations"],
    website: "thoughtfulapp.co",
    isCurrent: true
  },
  {
    company: "Nodetus Integrators LLC",
    title: "Founder",
    employmentType: "Full-time",
    startDate: "Feb 2017",
    endDate: "Present",
    duration: "9 yrs 4 mos",
    location: "Arlington, Virginia, United States · Hybrid",
    description: "Clients: Maximus Federal, Sprezzatura, A-Frame Solutions, Disca, IME, AFS",
    skills: ["Product Development", "Business Strategy"]
  },
  {
    company: "Tria Federal (Tria)",
    title: "Sr Technical Project Manager",
    employmentType: "Full-time",
    startDate: "Apr 2023",
    endDate: "Mar 2025",
    duration: "2 yrs",
    location: "Arlington, VA · Remote",
    description: "Worked on the Cerner -> Oracle EHRM project for the VA. Managed over 15 interfaces",
    skills: ["Agile Project Management", "Scrum"]
  },
  {
    company: "Tria Federal (Tria)",
    title: "Project Manager Scrum Master",
    employmentType: "Full-time",
    startDate: "Apr 2020",
    endDate: "Apr 2023",
    duration: "3 yrs 1 mo",
    location: "Remote",
    description: "Managed interface teams from Oracle (formerly Cerner) on VA EHRM project as teams configured/migrated to modern HL7/FHIR interfaces from legacy systems.",
    skills: ["Agile Project Management", "Scrum"]
  },
  {
