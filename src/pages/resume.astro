// Inline emphasis: **bold** -> <strong>, @@metric@@ -> amber span
const renderEmphasis = (s: string) =>
  s
    .replace(/@@(.+?)@@/g, '<span class="metric">$1</span>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
---

<Layout title="Resume - Erikk Shupp" description="Professional resume of Erikk Shupp - Sr. Technical Product Manager">
  <div class="resume-sheet">
    <div class="sheet-bar"></div>

    <div class="resume-shell">
      <a href="/about" class="back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to About
      </a>

      <header class="resume-header">
        <h1 class="name">Erikk Shupp<span class="dot">.</span></h1>
        <p class="role">Sr. Technical Product Manager</p>
        <p class="tagline">AI-Native · Health IT · Procurement &amp; Acquisitions · Executive Strategy</p>

        <div class="contact-row">
          {contactItems.map((item) => (
            <span class="contact-item">
              <span class="diamond">◆</span>
              {item.href ? (
                <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel="noopener noreferrer">{item.label}</a>
              ) : (
                <span>{item.label}</span>
              )}
            </span>
          ))}
        </div>

        <p class="summary" set:html={renderEmphasis(
          "Senior technical product manager spanning federal GovTech, health IT, and AI-native delivery. **8+ years** building enterprise GTM, modernizing clinical and EHR systems, and steering Agile programs through **FedRAMP** and **ATO** — pairing product strategy, design, and hands-on engineering."
        )} />
      </header>

      <div class="resume-grid">
        <main class="resume-main">
          <section>
            <div class="sec-head"><h2>Relevant Experience</h2></div>

            {experiences.map((job, i) => (
              <article class="exp-item">
                <div class={`exp-logo ${i % 2 === 0 ? 'teal' : 'dark'}`}>
                  <span>{job.company.charAt(0)}</span>
                </div>

                <div class="exp-body">
                  <div class="exp-top">
                    <h3 class="exp-title">{job.title}</h3>
                    <span class="exp-dates">{job.startDate} — {job.endDate || "Present"}</span>
                  </div>
                  <p class="exp-meta">
                    {job.company}
                    <span class="mid-dot">·</span>{job.employmentType}
                    <span class="mid-dot">·</span>{job.location}
                  </p>
                  {job.context && (
                    <p class="exp-context" set:html={renderEmphasis(job.context)} />
                  )}

                  {job.bullets && (
                    <ul class="exp-bullets">
                      {job.bullets.map((b) => (
                        <li set:html={renderEmphasis(b)} />
                      ))}
                    </ul>
                  )}

                  {job.governance && (
                    <p class="exp-gov">
                      <span class="gov-label">governance</span>
                      {job.governance.map((g) => (
                        <span class="gov-chip">{g}</span>
                      ))}
                    </p>
                  )}
                </div>
              </article>
            ))}
          </section>

          <section class="other-exp">
            <div class="sec-head"><h2>Other Experience</h2></div>
            {otherExperience.map((item) => (
              <article class="exp-item compact">
                <div class="exp-logo dark"><span>{item.company.charAt(0)}</span></div>
                <div class="exp-body">
                  <h3 class="exp-title small">{item.title}</h3>
                  <p class="exp-meta">{item.company}<span class="mid-dot">·</span>{item.dates}</p>
                </div>
              </article>
            ))}
          </section>
        </main>

        <aside class="resume-aside">
          <section class="aside-block">
            <h4 class="aside-head">Core</h4>
            <div class="pill-cloud">
              {coreCompetencies.map((c) => (
                <span class="pill core">{c}</span>
              ))}
            </div>
          </section>

          <section class="aside-block">
            <h4 class="aside-head">Tech</h4>
            <div class="pill-cloud">
              {techStack.map((t) => (
                <span class="pill">{t}</span>
              ))}
            </div>
          </section>

          <section class="aside-block">
            <h4 class="aside-head">Education</h4>
            {education.map((edu) => (
              <div class="edu-item">
                <p class="edu-degree">{edu.degree}</p>
                <p class="edu-meta">{edu.school}</p>
                <p class="edu-meta light">{edu.detail}</p>
              </div>
            ))}
          </section>

          <section class="aside-block">
            <h4 class="aside-head">Certifications</h4>
            <ul class="cert-list">
              {certifications.map((cert) => (
                <li><span class="diamond">◆</span>{cert}</li>
              ))}
            </ul>
          </section>
        </aside>
      </div>

      <section class="spec-section">
        <div class="sec-head"><h2>Specializations</h2></div>
        <div class="spec-grid">
          {specializations.map((s) => (
            <div class="spec-card">
              <p class="spec-title">{s.title}</p>
              <p class="spec-org">{s.org}</p>
            </div>
          ))}
        </div>
      </section>

      <footer class="resume-footer">
        <div class="resume-actions">
          <button class="btn btn-primary" onclick="window.print()">
            <Icon name="Printer" size={18} weight="duotone" />
            Print
          </button>
          <a href="/api/resume.pdf" class="btn btn-secondary">
            <Icon name="Download" size={18} weight="duotone" />
            Download PDF
          </a>
        </div>
      </footer>
    </div>
  </div>
</Layout>

<style>
  /* Load editorial typefaces matching the PDF (slab name + serif body + mono labels) */
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Roboto+Slab:wght@600;700;800&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap');

  .resume-sheet {
    /* Resume-scoped palette (warm, editorial) */
    --r-bg: #f5f3ec;
    --r-surface: #faf8f2;
    --r-ink: #262420;
    --r-muted: #6f6d65;
    --r-teal: #5f7d80;
    --r-teal-soft: rgba(95, 125, 128, 0.10);
    --r-teal-line: rgba(95, 125, 128, 0.28);
    --r-amber: #bd6f31;
    --r-border: #ddd8cb;
    --r-dash: rgba(95, 125, 128, 0.22);

    --r-serif: 'Source Serif 4', Georgia, 'Times New Roman', serif;
    --r-slab: 'Roboto Slab', 'Source Serif 4', Georgia, serif;
    --r-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;

    background: var(--r-bg);
    color: var(--r-ink);
    min-height: 100vh;
    /* Break out of the Layout's centered, 960px-capped <main> so the
       resume spans the full window to the right of the side nav. */
    width: calc(100vw - 240px);
    margin: -2rem 0 -2rem -2rem;
    padding: 0;
    overflow-x: hidden;
  }

  html.dark .resume-sheet {
    --r-bg: #1b1a17;
    --r-surface: #232220;
    --r-ink: #e9e6df;
    --r-muted: #a29f96;
    --r-teal: #8fb1b3;
    --r-teal-soft: rgba(143, 177, 179, 0.10);
    --r-teal-line: rgba(143, 177, 179, 0.28);
    --r-amber: #d9985a;
    --r-border: #353330;
    --r-dash: rgba(143, 177, 179, 0.22);
  }

  .sheet-bar {
    height: 6px;
    background: linear-gradient(90deg, var(--r-teal), color-mix(in srgb, var(--r-teal) 55%, #34484a));
  }

  .resume-shell {
    max-width: 1500px;
    margin: 0 auto;
    padding: 2rem clamp(2rem, 4vw, 5rem) 3.5rem;
  }

  /* Back Link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--r-muted);
    text-decoration: none;
    font-family: var(--r-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .back-link:hover { color: var(--r-teal); }
  .back-link:hover svg { transform: translateX(-3px); }
  .back-link svg { transition: transform 0.2s ease; }

  /* Header */
  .resume-header { margin-bottom: 2.25rem; }

  .name {
    font-family: var(--r-slab);
    font-weight: 800;
    font-size: clamp(2.6rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--r-ink);
    margin: 0 0 0.5rem;
  }
  .name .dot { color: var(--r-teal); }

  .role {
    font-family: var(--r-mono);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--r-teal);
    margin: 0 0 0.5rem;
  }

  .tagline {
    font-family: var(--r-mono);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--r-muted);
    margin: 0 0 1.1rem;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-family: var(--r-mono);
    font-size: 0.82rem;
    margin-bottom: 1.5rem;
  }
  .contact-item { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--r-ink); }
  .contact-item a { color: var(--r-ink); text-decoration: none; }
  .contact-item a:hover { color: var(--r-teal); text-decoration: underline; }
  .diamond { color: var(--r-teal); font-size: 0.6rem; line-height: 1; }

  .summary {
    font-family: var(--r-serif);
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--r-ink);
    max-width: 760px;
    margin: 0;
  }
  .summary :global(strong) { font-weight: 700; }

  /* Shared emphasis */
  .resume-sheet :global(strong) { color: var(--r-ink); font-weight: 700; }
  .resume-sheet :global(.metric) {
    font-family: var(--r-mono);
    font-weight: 700;
    font-size: 0.92em;
    color: var(--r-amber);
  }

  /* Grid */
  .resume-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 3.5rem;
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--r-border);
    position: relative;
  }
  .resume-aside {
    border-left: 1px solid var(--r-border);
    padding-left: 2.25rem;
  }

  /* Section heads */
  .sec-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }
  .sec-head h2 {
    font-family: var(--r-mono);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--r-teal);
    margin: 0;
    white-space: nowrap;
  }
  .sec-head::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--r-teal-line);
  }

  /* Experience */
  .exp-item {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 1.1rem;
    padding-bottom: 1.6rem;
    margin-bottom: 1.6rem;
    border-bottom: 1px dashed var(--r-dash);
  }
  .exp-item:last-child { border-bottom: none; margin-bottom: 0; }
  .exp-item.compact { padding-bottom: 1.1rem; margin-bottom: 1.1rem; }

  .exp-logo {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--r-slab);
    font-weight: 700;
    font-size: 1.4rem;
    color: #f7f5ef;
    flex-shrink: 0;
  }
  .exp-logo.teal { background: var(--r-teal); }
  .exp-logo.dark { background: #34322d; }
  html.dark .exp-logo.dark { background: #45433d; }

  .exp-body { min-width: 0; }
  .exp-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .exp-title {
    font-family: var(--r-serif);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--r-ink);
    margin: 0;
    line-height: 1.2;
  }
  .exp-title.small { font-size: 1.1rem; }
  .exp-dates {
    font-family: var(--r-mono);
    font-size: 0.78rem;
    color: var(--r-muted);
    white-space: nowrap;
  }
  .exp-meta {
    font-family: var(--r-mono);
    font-size: 0.78rem;
    color: var(--r-teal);
    margin: 0.3rem 0 0;
  }
  .mid-dot { color: var(--r-muted); margin: 0 0.45rem; opacity: 0.7; }

  .exp-context {
    font-family: var(--r-serif);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--r-muted);
    margin: 0.55rem 0 0.65rem;
  }

  .exp-bullets {
    margin: 0.65rem 0 0;
    padding: 0;
    list-style: none;
  }
  .exp-bullets li {
    position: relative;
    padding-left: 1.25rem;
    font-family: var(--r-serif);
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--r-ink);
    margin-bottom: 0.45rem;
    max-width: 760px;
  }
  .exp-bullets li::before {
    content: '◆';
    position: absolute;
    left: 0;
    top: 0.05em;
    font-size: 0.55rem;
    color: var(--r-teal);
  }

  .exp-gov {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin: 0.85rem 0 0;
  }
  .gov-label {
    font-family: var(--r-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--r-muted);
    margin-right: 0.25rem;
  }
  .gov-chip {
    font-family: var(--r-mono);
