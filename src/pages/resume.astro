    skills: ["AWS", "FedRAMP", "Product Management"]
  },
  {
    company: "RWD Consulting, LLC",
    title: "Technical Project Manager",
    employmentType: "Full-time",
    startDate: "Jan 2018",
    endDate: "Feb 2019",
    duration: "1 yr 2 mos",
    description: "Developed Federal CRM from scratch; DHS IT contracts, managed 6 FTEs; contributed to 165% revenue growth via proposal development and capture.",
    skills: ["Federal CRM", "DHS Contracts"]
  },
  {
    company: "Highlight",
