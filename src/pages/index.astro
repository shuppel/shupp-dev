---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../config/site.ts';
import LiquidHero from '../components/LiquidHero.astro';

// Get latest blog post for press section
const allPosts = await getCollection('blog');
const latestPost = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  [0];

// Get thoughtful apps count
const allApps = await getCollection('thoughtful-apps');
const activeApps = allApps.filter(a => a.data.status !== 'shelved');
---

<Layout title="Press Kit — Erikk Shupp">
  <!-- Hero / Identity -->
  <section class="pk-hero">
    <LiquidHero class="pk-hero-liquid" />
    <div class="pk-hero-content">
      <div class="pk-headshot">
        <img src="/images/about/esheadshot.jpg" alt="Erikk Shupp" width="160" height="160" />
      </div>
      <h1>Erikk Shupp</h1>
      <p class="pk-title">{siteConfig.author.title}</p>
      <p class="pk-location">{siteConfig.author.location}</p>
      <p class="pk-tagline">{siteConfig.tagline}</p>
    </div>
  </section>

  <!-- Bio -->
  <section class="pk-section pk-bio">
    <h2 class="pk-section-title">Bio</h2>
    <div class="pk-bio-content">
      <p>Product manager and software engineer building human-first digital experiences. Founder of <strong>Thoughtful App Co.</strong> and host of the <strong>Humans Only</strong> podcast. Based in Arlington, VA — working at the intersection of human needs and technical possibilities.</p>
      <p>Unconventional path: English Creative Writing undergrad, Technology Management masters, open-source self-taught engineer. A true product manager with deep technical aptitude — from storytelling to shipping software.</p>
    </div>
  </section>

  <!-- Thoughtful App Co. — Primary Spotlight -->
  <section class="pk-section pk-venture pk-venture-primary">
    <div class="pk-venture-badge">Featured Venture</div>
    <div class="pk-venture-header">
      <div class="pk-venture-logo">
        <span class="pk-logo-icon">&#x1F9E0;</span>
      </div>
      <div>
        <h2 class="pk-venture-name">Thoughtful App Co.</h2>
        <p class="pk-venture-tagline">{siteConfig.ventures.thoughtfulAppCo.tagline}</p>
      </div>
    </div>
    <p class="pk-venture-description">A product studio building thoughtful software that respects users' time and attention. Every concept starts with a real human problem and ends with a solution designed for people, not metrics. Currently exploring <strong>{activeApps.length} active concepts</strong> across health, finance, and digital wellness.</p>
    <div class="pk-venture-links">
      <a href="/thoughtful-app-co" class="pk-btn pk-btn-primary">View App Concepts</a>
      <a href={siteConfig.ventures.thoughtfulAppCo.url} class="pk-btn pk-btn-outline" target="_blank" rel="noopener noreferrer">thoughtfulapp.co</a>
      <a href={siteConfig.ventures.thoughtfulAppCo.youtube} class="pk-btn pk-btn-ghost" target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href={siteConfig.ventures.thoughtfulAppCo.tiktok} class="pk-btn pk-btn-ghost" target="_blank" rel="noopener noreferrer">TikTok</a>
      <a href={siteConfig.ventures.thoughtfulAppCo.github} class="pk-btn pk-btn-ghost" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </section>

  <!-- Humans Only Podcast -->
  <section class="pk-section pk-venture pk-venture-podcast">
    <div class="pk-venture-badge">Podcast</div>
    <div class="pk-venture-header">
      <div class="pk-venture-logo">
        <span class="pk-logo-icon">&#x1F399;</span>
      </div>
      <div>
        <h2 class="pk-venture-name">Humans Only</h2>
        <p class="pk-venture-tagline">{siteConfig.ventures.humansOnlyPodcast.tagline}</p>
      </div>
    </div>
    <p class="pk-venture-description">Exploring how emerging technology can better serve humanity. Conversations about the human side of tech — digital wellness, ethical AI, local-first software, and building products that actually matter.</p>
    <div class="pk-venture-links">
      <a href={siteConfig.ventures.humansOnlyPodcast.url} class="pk-btn pk-btn-primary" target="_blank" rel="noopener noreferrer">humansonly.fm</a>
      <a href={siteConfig.ventures.humansOnlyPodcast.spotify} class="pk-btn pk-btn-outline" target="_blank" rel="noopener noreferrer">Spotify</a>
      {siteConfig.ventures.humansOnlyPodcast.apple && (
        <a href={siteConfig.ventures.humansOnlyPodcast.apple} class="pk-btn pk-btn-ghost" target="_blank" rel="noopener noreferrer">Apple Podcasts</a>
      )}
      {siteConfig.ventures.humansOnlyPodcast.youtube && (
        <a href={siteConfig.ventures.humansOnlyPodcast.youtube} class="pk-btn pk-btn-ghost" target="_blank" rel="noopener noreferrer">YouTube</a>
      )}
    </div>
  </section>

  <!-- Boobo the Spinosaur -->
  <section class="pk-section pk-venture pk-venture-boobo">
    <div class="pk-venture-badge">Series</div>
    <div class="pk-venture-header">
      <div class="pk-venture-logo">
        <span class="pk-logo-icon">&#x1F996;</span>
      </div>
      <div>
        <h2 class="pk-venture-name">Boobo the Spinosaur</h2>
        <p class="pk-venture-tagline">A Thoughtful App Co. original</p>
      </div>
    </div>
    <div class="pk-venture-links">
      <a href={siteConfig.ventures.booboTheSpinosaur.youtube} class="pk-btn pk-btn-primary" target="_blank" rel="noopener noreferrer">Watch on YouTube</a>
    </div>
  </section>

  <!-- Social Links — Personal & Business -->
  <section class="pk-section pk-socials">
    <h2 class="pk-section-title">Connect</h2>
    <div class="pk-socials-grid">
      <div class="pk-social-group">
        <h3 class="pk-social-group-title">Personal</h3>
        <div class="pk-social-links">
          <a href={`mailto:${siteConfig.email}`} class="pk-social-link">
            <span class="pk-social-icon">&#x2709;</span>
            <span class="pk-social-label">{siteConfig.email}</span>
          </a>
          <a href={siteConfig.social.linkedin} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">in</span>
            <span class="pk-social-label">LinkedIn</span>
          </a>
          <a href={siteConfig.social.bluesky} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x1F98B;</span>
            <span class="pk-social-label">Bluesky</span>
          </a>
          <a href={siteConfig.social.twitter} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x1D54F;</span>
            <span class="pk-social-label">X</span>
          </a>
          <a href={siteConfig.social.instagram} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x1F4F7;</span>
            <span class="pk-social-label">Instagram</span>
          </a>
          <a href={siteConfig.social.github} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&lt;/&gt;</span>
            <span class="pk-social-label">GitHub</span>
          </a>
        </div>
      </div>
      <div class="pk-social-group">
        <h3 class="pk-social-group-title">Thoughtful App Co.</h3>
        <div class="pk-social-links">
          <a href={`mailto:${siteConfig.ventures.thoughtfulAppCo.email}`} class="pk-social-link">
            <span class="pk-social-icon">&#x2709;</span>
            <span class="pk-social-label">{siteConfig.ventures.thoughtfulAppCo.email}</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.url} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x1F310;</span>
            <span class="pk-social-label">thoughtfulapp.co</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.youtube} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x25B6;</span>
            <span class="pk-social-label">YouTube</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.tiktok} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x266B;</span>
            <span class="pk-social-label">TikTok</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.github} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&lt;/&gt;</span>
            <span class="pk-social-label">GitHub</span>
          </a>
        </div>
      </div>
      <div class="pk-social-group">
        <h3 class="pk-social-group-title">Humans Only Podcast</h3>
        <div class="pk-social-links">
          <a href={`mailto:${siteConfig.ventures.humansOnlyPodcast.email}`} class="pk-social-link">
            <span class="pk-social-icon">&#x2709;</span>
            <span class="pk-social-label">{siteConfig.ventures.humansOnlyPodcast.email}</span>
          </a>
          <a href={siteConfig.ventures.humansOnlyPodcast.url} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x1F310;</span>
            <span class="pk-social-label">humansonly.fm</span>
          </a>
          <a href={siteConfig.ventures.humansOnlyPodcast.spotify} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x1F3B5;</span>
            <span class="pk-social-label">Spotify</span>
          </a>
          <a href={siteConfig.ventures.humansOnlyPodcast.youtube} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon">&#x25B6;</span>
            <span class="pk-social-label">YouTube</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Press Assets -->
  <section class="pk-section pk-assets">
    <h2 class="pk-section-title">Press Assets</h2>
    <p class="pk-assets-intro">High-resolution photos, logos, and brand assets for media use.</p>
    <div class="pk-assets-grid">
      <div class="pk-asset-card">
        <div class="pk-asset-preview">
          <img src="/images/about/esheadshot.jpg" alt="Erikk Shupp headshot" width="300" height="300" />
        </div>
        <div class="pk-asset-info">
          <span class="pk-asset-name">Headshot</span>
          <a href="/images/about/esheadshot.jpg" download class="pk-btn pk-btn-small">Download</a>
        </div>
      </div>
      <div class="pk-asset-card">
        <div class="pk-asset-preview pk-asset-logo-preview">
          <span class="pk-brand-mark">shupp.dev</span>
        </div>
        <div class="pk-asset-info">
          <span class="pk-asset-name">Wordmark</span>
          <span class="pk-asset-note">SVG available on request</span>
        </div>
      </div>
      <div class="pk-asset-card">
        <div class="pk-asset-preview pk-asset-colors-preview">
          <div class="pk-color-swatch" style="background: #14080E;" title="#14080E"></div>
          <div class="pk-color-swatch" style="background: #49475B;" title="#49475B"></div>
          <div class="pk-color-swatch" style="background: #799496;" title="#799496"></div>
          <div class="pk-color-swatch" style="background: #ACC196;" title="#ACC196"></div>
          <div class="pk-color-swatch" style="background: #E9EB9E;" title="#E9EB9E"></div>
        </div>
        <div class="pk-asset-info">
          <span class="pk-asset-name">Brand Colors</span>
          <span class="pk-asset-note">5-color palette</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="pk-section pk-quick-links">
    <h2 class="pk-section-title">More</h2>
    <div class="pk-links-grid">
      <a href="/about" class="pk-link-card">
        <h3>About</h3>
        <p>Full background, philosophy, and skills</p>
      </a>
      <a href="/portfolio" class="pk-link-card">
        <h3>Portfolio</h3>
        <p>Projects and case studies</p>
      </a>
      <a href="/blog" class="pk-link-card">
        <h3>Blog</h3>
        <p>Writing on tech, product, and design</p>
      </a>
      <a href="/resume" class="pk-link-card">
        <h3>Resume</h3>
        <p>Experience and credentials</p>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ===== Press Kit Hero ===== */
  .pk-hero {
    position: relative;
    text-align: center;
    padding: 5rem 1.5rem 4rem;
    min-height: 420px;
    overflow: hidden;
    margin-bottom: 0;
  }

  .pk-hero-liquid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    opacity: 0.7;
  }

  .pk-hero-content {
    position: relative;
    z-index: 2;
    animation: pk-fade-up 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .pk-headshot {
    width: 160px;
    height: 160px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--color-accent);
    box-shadow: 0 8px 30px rgba(20, 8, 14, 0.15);
  }

  .pk-headshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pk-hero h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    background: linear-gradient(45deg, var(--color-dark), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html.dark .pk-hero h1 {
    background: linear-gradient(45deg, #f3f4f6, #e9eb9e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pk-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin-bottom: 0.25rem;
    font-family: var(--font-secondary-header);
  }

  html.dark .pk-title {
    color: var(--color-accent);
  }

  .pk-location {
    font-size: 0.95rem;
    color: var(--color-tertiary);
    margin-bottom: 0.75rem;
    font-family: var(--font-body);
  }

  .pk-tagline {
    font-size: 1.4rem;
    font-style: italic;
    color: var(--color-secondary);
    font-family: var(--font-body);
    opacity: 0;
    animation: pk-fade-up 0.8s 0.3s forwards cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  html.dark .pk-tagline {
    color: #d1d5db;
  }

  /* ===== Shared Section Styles ===== */
  .pk-section {
    max-width: 860px;
    margin: 3.5rem auto;
    padding: 0 1.5rem;
  }

  .pk-section-title {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-tertiary);
    margin-bottom: 1.5rem;
    font-family: var(--font-secondary-header);
  }

  html.dark .pk-section-title {
    color: var(--color-accent);
  }

  /* ===== Bio ===== */
  .pk-bio-content p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-secondary);
    margin-bottom: 1rem;
    font-family: var(--font-body);
  }

  .pk-bio-content p:last-child {
    margin-bottom: 0;
  }

  html.dark .pk-bio-content p {
    color: #d1d5db;
  }

  .pk-bio-content strong {
    color: var(--color-dark);
    font-weight: 600;
  }

  html.dark .pk-bio-content strong {
    color: #f3f4f6;
  }

  /* ===== Venture Cards ===== */
  .pk-venture {
    max-width: 860px;
    background: white;
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 4px 20px rgba(20, 8, 14, 0.06);
    border: 1px solid rgba(121, 148, 150, 0.12);
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .pk-venture:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(20, 8, 14, 0.1);
  }

  html.dark .pk-venture {
    background: #23232b;
    border-color: rgba(233, 235, 158, 0.1);
  }

  .pk-venture-badge {
    position: absolute;
    top: -12px;
    left: 2rem;
    background: linear-gradient(135deg, var(--color-tertiary), var(--color-accent));
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-family: var(--font-secondary-header);
  }

  html.dark .pk-venture-badge {
    color: #23232b;
  }

  .pk-venture-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .pk-venture-logo {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--color-secondary), var(--color-tertiary));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pk-venture-podcast .pk-venture-logo {
    background: linear-gradient(135deg, var(--color-dark), var(--color-secondary));
  }

  .pk-venture-boobo .pk-venture-logo {
    background: linear-gradient(135deg, #4a7c59, var(--color-accent));
  }

  .pk-logo-icon {
    font-size: 1.6rem;
    line-height: 1;
  }

  .pk-venture-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-dark);
    margin: 0;
    line-height: 1.2;
  }

  html.dark .pk-venture-name {
    color: #f3f4f6;
  }

  .pk-venture-tagline {
    font-size: 0.95rem;
    color: var(--color-tertiary);
    margin: 0.2rem 0 0;
    font-family: var(--font-body);
  }

  .pk-venture-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-secondary);
    margin-bottom: 1.5rem;
    font-family: var(--font-body);
  }

  html.dark .pk-venture-description {
    color: #d1d5db;
  }

  .pk-venture-description strong {
    color: var(--color-dark);
  }

  html.dark .pk-venture-description strong {
    color: #f3f4f6;
  }

  .pk-venture-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ===== Buttons ===== */
  .pk-btn {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-secondary-header);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    cursor: pointer;
  }

  .pk-btn-primary {
    background: var(--color-tertiary);
    color: white;
    box-shadow: 0 4px 12px rgba(121, 148, 150, 0.3);
  }

  .pk-btn-primary:hover {
    background: linear-gradient(135deg, var(--color-tertiary), var(--color-accent));
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(121, 148, 150, 0.4);
  }

  html.dark .pk-btn-primary {
    background: var(--color-accent);
    color: #23232b;
  }

  html.dark .pk-btn-primary:hover {
    box-shadow: 0 6px 16px rgba(233, 235, 158, 0.3);
  }

  .pk-btn-outline {
    background: transparent;
    color: var(--color-tertiary);
    border: 2px solid var(--color-tertiary);
  }

  .pk-btn-outline:hover {
    background: var(--color-tertiary);
    color: white;
    transform: translateY(-2px);
  }

  html.dark .pk-btn-outline {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  html.dark .pk-btn-outline:hover {
    background: var(--color-accent);
    color: #23232b;
  }

  .pk-btn-ghost {
    background: transparent;
    color: var(--color-secondary);
    border: 1px solid rgba(121, 148, 150, 0.25);
  }

  .pk-btn-ghost:hover {
    border-color: var(--color-tertiary);
    color: var(--color-tertiary);
    transform: translateY(-2px);
  }

  html.dark .pk-btn-ghost {
    color: #d1d5db;
    border-color: rgba(233, 235, 158, 0.2);
  }

  html.dark .pk-btn-ghost:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .pk-btn-small {
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    background: var(--color-tertiary);
    color: white;
    border-radius: 20px;
  }

  .pk-btn-small:hover {
    background: var(--color-accent);
    transform: translateY(-1px);
  }

  html.dark .pk-btn-small {
    background: var(--color-accent);
    color: #23232b;
  }

  /* ===== Social Links ===== */
  .pk-socials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .pk-social-group-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-dark);
    margin-bottom: 1rem;
    font-family: var(--font-secondary-header);
  }

  html.dark .pk-social-group-title {
    color: #f3f4f6;
  }

  .pk-social-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pk-social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-secondary);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .pk-social-link:hover {
    background: rgba(121, 148, 150, 0.08);
    color: var(--color-tertiary);
    transform: translateX(4px);
  }

  html.dark .pk-social-link {
    color: #d1d5db;
  }

  html.dark .pk-social-link:hover {
    background: rgba(233, 235, 158, 0.08);
    color: var(--color-accent);
  }

  .pk-social-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 700;
    background: rgba(121, 148, 150, 0.1);
    border-radius: 8px;
    flex-shrink: 0;
    color: var(--color-tertiary);
    font-family: var(--font-secondary-header);
  }

