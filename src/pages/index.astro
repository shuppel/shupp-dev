---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site.ts';
import Icon from '../components/Icon/Icon.astro';
---

<Layout title="Press Kit — Erikk Shupp">
  <!-- Hero / Identity -->
  <section class="pk-hero">
    <div class="pk-hero-card quantum-outline">
      <div class="pk-hero-headshot">
        <img src="/images/about/esheadshot.jpg" alt="Erikk Shupp" width="160" height="160" />
      </div>
      <div class="pk-hero-info">
        <h1>Erikk Shupp</h1>
        <p class="pk-title">{siteConfig.author.title}</p>
        <p class="pk-location">
          <span class="pk-location-dot" aria-hidden="true"></span>
          {siteConfig.author.location}
        </p>
        <p class="pk-tagline">{siteConfig.tagline}</p>
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="pk-section pk-bio">
    <h2 class="pk-section-title">Bio</h2>
    <div class="pk-bio-content">
      <p>A true strategic founder: product, design, development, marketing and writing. Founder of <strong>Thoughtful App Co.</strong> and host of the <strong>Humans Only</strong> podcast. Based in Arlington, VA — working at the intersection of human needs and technical possibilities.</p>
      <p>Unconventional path: English Creative Writing undergrad, Technology Management masters, open-source self-taught engineer. A fractional founder with end-to-end fluency — from storytelling to shipping software.</p>
    </div>
  </section>

  <!-- Ventures & Companies -->
  <section class="pk-section">
    <h2 class="pk-section-title">Companies & Ventures</h2>
    <div class="pk-companies-grid">
      <!-- Thoughtful App Co. -->
      <div class="pk-company-card pk-company-taco">
        <div class="pk-company-header">
          <div class="pk-company-logo">
            <Icon name="Brain" size={20} weight="duotone" color="white" />
          </div>
          <div class="pk-company-info">
            <h3 class="pk-company-name">Thoughtful App Co.</h3>
            <span class="pk-company-type">Product Studio</span>
          </div>
        </div>
        <p class="pk-company-description">Building human-centered software that respects privacy and prioritizes user wellbeing.</p>
        <div class="pk-company-links">
          <a href={siteConfig.ventures.thoughtfulAppCo.url} class="pk-company-link" target="_blank" rel="noopener noreferrer">
            <Icon name="Globe" size={14} weight="duotone" />
            thoughtfulapp.co
          </a>
        </div>
      </div>

      <!-- Nodetus -->
      <div class="pk-company-card pk-company-nodetus">
        <div class="pk-company-header">
          <div class="pk-company-logo">
            <Icon name="Building" size={20} weight="duotone" color="white" />
          </div>
          <div class="pk-company-info">
            <h3 class="pk-company-name">Nodetus</h3>
            <span class="pk-company-type">Federal Consulting</span>
          </div>
        </div>
        <p class="pk-company-description">Strategic technology consulting for federal agencies and government contractors.</p>
        <div class="pk-company-links">
          <a href="https://nodetus.com" class="pk-company-link" target="_blank" rel="noopener noreferrer">
            <Icon name="Globe" size={14} weight="duotone" />
            nodetus.com
          </a>
        </div>
      </div>

      <!-- Humans Only Podcast -->
      <div class="pk-company-card pk-company-podcast">
        <div class="pk-company-header">
          <div class="pk-company-logo">
            <Icon name="Microphone" size={20} weight="duotone" color="white" />
          </div>
          <div class="pk-company-info">
            <h3 class="pk-company-name">Humans Only</h3>
            <span class="pk-company-type">Podcast</span>
          </div>
        </div>
        <p class="pk-company-description">Exploring how emerging technology can better serve humanity.</p>
        <div class="pk-company-links">
          <a href={siteConfig.ventures.humansOnlyPodcast.url} class="pk-company-link" target="_blank" rel="noopener noreferrer">
            <Icon name="Globe" size={14} weight="duotone" />
            humansonly.fm
          </a>
          <a href={siteConfig.ventures.humansOnlyPodcast.spotify} class="pk-company-link" target="_blank" rel="noopener noreferrer">
            <Icon name="SpotifyLogo" size={14} weight="duotone" />
            Spotify
          </a>
        </div>
      </div>

      <!-- Boobo the Spinosaur -->
      <div class="pk-company-card pk-company-boobo">
        <div class="pk-company-header">
          <div class="pk-company-logo">
            <Icon name="PawPrint" size={20} weight="duotone" color="white" />
          </div>
          <div class="pk-company-info">
            <h3 class="pk-company-name">Boobo the Spinosaur</h3>
            <span class="pk-company-type">Original Series</span>
          </div>
        </div>
        <p class="pk-company-description">A children's series about a thoughtful dinosaur navigating life's adventures.</p>
        <div class="pk-company-links">
          <a href={siteConfig.ventures.booboTheSpinosaur.youtube} class="pk-company-link" target="_blank" rel="noopener noreferrer">
            <Icon name="YoutubeLogo" size={14} weight="duotone" />
            YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Links — Personal & Business -->
  <section class="pk-section pk-socials">
    <h2 class="pk-section-title">Connect</h2>
    <div class="pk-socials-grid">
      <div class="pk-social-group">
        <h3 class="pk-social-group-title">Personal</h3>
        <div class="pk-social-links">
          <a href={`mailto:${siteConfig.email}`} class="pk-social-link">
            <span class="pk-social-icon"><Icon name="Envelope" size={16} weight="duotone" /></span>
            <span class="pk-social-label">{siteConfig.email}</span>
          </a>
          <a href={siteConfig.social.linkedin} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="LinkedinLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">LinkedIn</span>
          </a>
          <a href={siteConfig.social.bluesky} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="Butterfly" size={16} weight="duotone" /></span>
            <span class="pk-social-label">Bluesky</span>
          </a>
          <a href={siteConfig.social.twitter} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="XLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">X</span>
          </a>
          <a href={siteConfig.social.instagram} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="InstagramLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">Instagram</span>
          </a>
          <a href={siteConfig.social.github} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="GithubLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">GitHub</span>
          </a>
        </div>
      </div>
      <div class="pk-social-group">
        <h3 class="pk-social-group-title">Thoughtful App Co.</h3>
        <div class="pk-social-links">
          <a href={`mailto:${siteConfig.ventures.thoughtfulAppCo.email}`} class="pk-social-link">
            <span class="pk-social-icon"><Icon name="Envelope" size={16} weight="duotone" /></span>
            <span class="pk-social-label">{siteConfig.ventures.thoughtfulAppCo.email}</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.url} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="Globe" size={16} weight="duotone" /></span>
            <span class="pk-social-label">thoughtfulapp.co</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.youtube} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="YoutubeLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">YouTube</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.tiktok} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="TiktokLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">TikTok</span>
          </a>
          <a href={siteConfig.ventures.thoughtfulAppCo.github} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="GithubLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">GitHub</span>
          </a>
        </div>
      </div>
      <div class="pk-social-group">
        <h3 class="pk-social-group-title">Humans Only Podcast</h3>
        <div class="pk-social-links">
          <a href={`mailto:${siteConfig.ventures.humansOnlyPodcast.email}`} class="pk-social-link">
            <span class="pk-social-icon"><Icon name="Envelope" size={16} weight="duotone" /></span>
            <span class="pk-social-label">{siteConfig.ventures.humansOnlyPodcast.email}</span>
          </a>
          <a href={siteConfig.ventures.humansOnlyPodcast.url} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="Globe" size={16} weight="duotone" /></span>
            <span class="pk-social-label">humansonly.fm</span>
          </a>
          <a href={siteConfig.ventures.humansOnlyPodcast.spotify} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="SpotifyLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">Spotify</span>
          </a>
          <a href={siteConfig.ventures.humansOnlyPodcast.youtube} class="pk-social-link" target="_blank" rel="noopener noreferrer">
            <span class="pk-social-icon"><Icon name="YoutubeLogo" size={16} weight="duotone" /></span>
            <span class="pk-social-label">YouTube</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Press Assets -->
  <section class="pk-section pk-assets">
    <h2 class="pk-section-title">Press Assets</h2>
    <p class="pk-assets-intro">High-resolution photos, logos, and brand assets for media use.</p>
    <div class="pk-assets-grid">
      <div class="pk-asset-card">
        <div class="pk-asset-preview">
          <img src="/images/about/esheadshot.jpg" alt="Erikk Shupp headshot" width="300" height="300" />
        </div>
        <div class="pk-asset-info">
          <span class="pk-asset-name">Headshot</span>
          <a href="/images/about/esheadshot.jpg" download class="pk-btn pk-btn-small">Download</a>
        </div>
      </div>
      <div class="pk-asset-card">
        <div class="pk-asset-preview pk-asset-logo-preview">
          <span class="pk-brand-mark">shupp.dev</span>
        </div>
        <div class="pk-asset-info">
          <span class="pk-asset-name">Wordmark</span>
          <span class="pk-asset-note">SVG available on request</span>
        </div>
      </div>
      <div class="pk-asset-card">
        <div class="pk-asset-preview pk-asset-colors-preview" role="img" aria-label="Brand palette: #14080E, #49475B, #799496, #ACC196, #E9EB9E">
          <div class="pk-color-swatch" style="background: #14080E;" title="#14080E"></div>
          <div class="pk-color-swatch" style="background: #49475B;" title="#49475B"></div>
          <div class="pk-color-swatch" style="background: #799496;" title="#799496"></div>
          <div class="pk-color-swatch" style="background: #ACC196;" title="#ACC196"></div>
          <div class="pk-color-swatch" style="background: #E9EB9E;" title="#E9EB9E"></div>
        </div>
        <div class="pk-asset-info">
          <span class="pk-asset-name">Brand Colors</span>
          <span class="pk-asset-note">5-color palette</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="pk-section pk-quick-links">
    <h2 class="pk-section-title">More</h2>
    <div class="pk-links-grid">
      <a href="/about" class="pk-link-card">
        <h3>About</h3>
        <p>Full background, philosophy, and skills</p>
      </a>
      <a href="/portfolio" class="pk-link-card">
        <h3>Portfolio</h3>
        <p>Projects and case studies</p>
      </a>
      <a href="/blog" class="pk-link-card">
        <h3>Blog</h3>
        <p>Writing on tech, product, and design</p>
      </a>
      <a href="/resume" class="pk-link-card">
        <h3>Resume</h3>
        <p>Experience and credentials</p>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ===== Animated Quantum Outline =====
     Lightweight CSS replacement for the heavy three.js hero —
     a slow conic gradient sweeps around the border. */
  @property --pk-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  .quantum-outline {
    position: relative;
    isolation: isolate;
  }

  .quantum-outline::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1.5px;
    border-radius: inherit;
    background: conic-gradient(
      from var(--pk-angle),
      rgba(121, 148, 150, 0.0) 0%,
      rgba(121, 148, 150, 0.7) 18%,
      rgba(172, 193, 150, 0.85) 30%,
      rgba(233, 235, 158, 0.7) 42%,
      rgba(121, 148, 150, 0.0) 60%,
      rgba(121, 148, 150, 0.0) 100%
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: pk-rotate-outline 14s linear infinite;
    pointer-events: none;
    z-index: 0;
  }

  html.dark .quantum-outline::before {
    background: conic-gradient(
      from var(--pk-angle),
      rgba(172, 193, 150, 0.0) 0%,
      rgba(172, 193, 150, 0.55) 18%,
      rgba(233, 235, 158, 0.75) 30%,
      rgba(121, 148, 150, 0.6) 42%,
      rgba(172, 193, 150, 0.0) 60%,
      rgba(172, 193, 150, 0.0) 100%
    );
  }

  @keyframes pk-rotate-outline {
    to { --pk-angle: 360deg; }
  }

  @media (prefers-reduced-motion: reduce) {
    .quantum-outline::before {
      animation: none;
    }
  }

  /* Fallback for browsers without @property: render a static gradient ring */
  @supports not (background: conic-gradient(from 0deg, red, blue)) {
    .quantum-outline::before {
      background: linear-gradient(135deg, rgba(121, 148, 150, 0.4), rgba(172, 193, 150, 0.4), rgba(233, 235, 158, 0.4));
    }
  }

  /* ===== Press Kit Hero Card ===== */
  .pk-hero {
    max-width: 860px;
    margin: 2.5rem auto 0;
    padding: 0 1.5rem;
  }

  .pk-hero-card {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 2rem;
    padding: 1.75rem 2rem;
    border-radius: 18px;
    background: var(--surface);
    box-shadow: 0 6px 28px rgba(20, 8, 14, 0.06);
    animation: pk-fade-up 0.7s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .pk-hero-card {
      animation: none;
    }
  }

  .pk-hero-headshot {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-accent);
    box-shadow: 0 6px 22px rgba(20, 8, 14, 0.14);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .pk-hero-headshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pk-hero-info {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .pk-hero h1 {
    font-size: 2.4rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
    line-height: 1.1;
    background: linear-gradient(45deg, var(--color-dark), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html.dark .pk-hero h1 {
    background: linear-gradient(45deg, #f3f4f6, #e9eb9e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pk-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin: 0 0 0.3rem;
    font-family: var(--font-secondary-header);
    letter-spacing: 0.02em;
  }

  html.dark .pk-title {
    color: var(--color-accent);
  }

  .pk-location {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.88rem;
    color: var(--color-tertiary);
    margin: 0 0 0.65rem;
    font-family: var(--font-body);
  }

  .pk-location-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-tertiary);
    box-shadow: 0 0 0 3px rgba(121, 148, 150, 0.18);
  }

  .pk-tagline {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-secondary);
    font-family: var(--font-body);
    margin: 0;
  }

  html.dark .pk-tagline {
    color: var(--text-color);
  }

  /* ===== Shared Section Styles ===== */
  .pk-section {
    max-width: 860px;
    margin: 3.5rem auto;
    padding: 0 1.5rem;
  }

  .pk-section-title {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-tertiary);
    margin-bottom: 1.5rem;
    font-family: var(--font-secondary-header);
  }

  html.dark .pk-section-title {
    color: var(--color-accent);
  }

  /* ===== Bio ===== */
  .pk-bio-content p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-secondary);
    margin-bottom: 1rem;
    font-family: var(--font-body);
  }

  .pk-bio-content p:last-child {
    margin-bottom: 0;
  }

  html.dark .pk-bio-content p {
    color: var(--text-color);
  }

  .pk-bio-content strong {
    color: var(--text-strong);
    font-weight: 600;
  }

  /* ===== Company Cards Grid ===== */
  .pk-companies-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .pk-company-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 1.25rem;
    border: 1px solid var(--border-subtle);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pk-company-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(20, 8, 14, 0.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .pk-company-card {
      transition: none;
    }
    .pk-company-card:hover {
      transform: none;
    }
  }

  .pk-company-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 0.75rem;
  }

  .pk-company-logo {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-secondary), var(--color-tertiary));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pk-company-taco .pk-company-logo {
    background: linear-gradient(135deg, var(--color-tertiary), var(--color-accent));
  }

  .pk-company-nodetus .pk-company-logo {
    background: linear-gradient(135deg, #49475B, #799496);
  }

  .pk-company-podcast .pk-company-logo {
    background: linear-gradient(135deg, var(--color-dark), var(--color-secondary));
  }

  .pk-company-boobo .pk-company-logo {
    background: linear-gradient(135deg, #4a7c59, var(--color-accent));
  }

  .pk-company-info {
    min-width: 0;
  }

  .pk-company-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-strong);
    margin: 0;
    line-height: 1.2;
    font-family: var(--font-secondary-header);
  }

  .pk-company-type {
    font-size: 0.75rem;
    color: var(--color-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-body);
  }

  html.dark .pk-company-type {
    color: var(--color-accent);
    opacity: 0.8;
  }

  .pk-company-description {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-secondary);
    margin: 0 0 0.875rem 0;
    font-family: var(--font-body);
  }

  html.dark .pk-company-description {
    color: var(--text-muted);
  }

  .pk-company-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pk-company-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    background: var(--hover-tint);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-secondary);
    text-decoration: none;
    font-family: var(--font-body);
    transition: all 0.2s ease;
  }

  .pk-company-link:hover {
    background: rgba(121, 148, 150, 0.15);
    color: var(--text-strong);
    transform: translateY(-1px);
  }

  .pk-company-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  html.dark .pk-company-link {
    color: var(--text-color);
  }

  html.dark .pk-company-link:hover {
    background: rgba(233, 235, 158, 0.15);
  }

  /* ===== Buttons ===== */
  .pk-btn {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-secondary-header);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    cursor: pointer;
  }

  .pk-btn-primary {
    background: var(--color-tertiary);
    color: var(--surface);
    box-shadow: 0 4px 12px rgba(121, 148, 150, 0.3);
  }

  .pk-btn-primary:hover {
    background: linear-gradient(135deg, var(--color-tertiary), var(--color-accent));
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(121, 148, 150, 0.4);
  }

  html.dark .pk-btn-primary {
    background: var(--color-accent);
    color: var(--color-dark);
  }

  html.dark .pk-btn-primary:hover {
    box-shadow: 0 6px 16px rgba(233, 235, 158, 0.3);
