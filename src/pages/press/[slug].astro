---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon/Icon.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedProjects from '../../components/RelatedProjects.astro';
import RelatedBlogPosts from '../../components/RelatedBlogPosts.astro';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const entries = await getCollection('press');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'press'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const TYPE_META: Record<string, { label: string; icon: string; cta: string }> = {
  'article':         { label: 'Article',     icon: 'Article',         cta: 'Read on' },
  'podcast-episode': { label: 'Podcast',     icon: 'Microphone',      cta: 'Listen on' },
  'podcast-guest':   { label: 'Guest Spot',  icon: 'MicrophoneStage', cta: 'Listen on' },
  'talk':            { label: 'Talk',        icon: 'Presentation',    cta: 'View on' },
  'interview':       { label: 'Interview',   icon: 'ChatsCircle',     cta: 'Read on' },
  'mention':         { label: 'Mention',     icon: 'Quotes',          cta: 'Read on' },
  'award':           { label: 'Award',       icon: 'Trophy',          cta: 'View on' },
  'video':           { label: 'Video',       icon: 'PlayCircle',      cta: 'Watch on' },
};

const meta = TYPE_META[entry.data.type] ?? { label: entry.data.type, icon: 'Bookmark', cta: 'View on' };

const formattedDate = new Date(entry.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const breadcrumbs = [
  { name: 'Press', url: '/press' },
  { name: entry.data.title }
];

const pressData = {
  press: {
    title: entry.data.title,
    description: entry.data.description,
    type: entry.data.type,
    pubDate: entry.data.pubDate.toISOString(),
    externalUrl: entry.data.externalUrl,
    outlet: entry.data.outlet,
    eventName: entry.data.eventName,
    location: entry.data.location,
    image: entry.data.coverImage,
    tags: entry.data.tags || [],
    guests: entry.data.guests || [],
  },
  breadcrumbs: [
    { name: 'Home', url: 'https://shupp.dev' },
    { name: 'Press', url: 'https://shupp.dev/press' },
    { name: entry.data.title, url: `https://shupp.dev/press/${entry.slug}` }
  ]
};
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  image={entry.data.coverImage || '/og-default.png'}
  keywords={entry.data.tags?.join(', ') || ''}
  jsonLdType="press"
  jsonLdData={pressData}
  canonicalUrl={entry.data.externalUrl}
>
  <Breadcrumbs items={breadcrumbs} />

  <article class="press-detail">
    <header class="press-detail-header">
      <div class="press-detail-type">
        <Icon name={meta.icon} size={18} weight="duotone" />
        <span>{meta.label}</span>
      </div>
      <h1 class="press-detail-title">{entry.data.title}</h1>
      <p class="press-detail-description">{entry.data.description}</p>

      <dl class="press-detail-meta">
        <div>
          <dt>Published</dt>
          <dd>{formattedDate}</dd>
        </div>
        {entry.data.outlet && (
          <div>
            <dt>Outlet</dt>
            <dd>
              {entry.data.outletUrl ? (
                <a href={entry.data.outletUrl} target="_blank" rel="noopener noreferrer">{entry.data.outlet}</a>
              ) : (
                entry.data.outlet
              )}
            </dd>
          </div>
        )}
        {entry.data.eventName && (
          <div>
            <dt>Event</dt>
            <dd>
              {entry.data.eventUrl ? (
                <a href={entry.data.eventUrl} target="_blank" rel="noopener noreferrer">{entry.data.eventName}</a>
              ) : (
                entry.data.eventName
              )}
              {entry.data.location && <span class="press-detail-location"> · {entry.data.location}</span>}
            </dd>
          </div>
        )}
        {entry.data.guests && entry.data.guests.length > 0 && (
          <div>
            <dt>Guest{entry.data.guests.length > 1 ? 's' : ''}</dt>
            <dd>{entry.data.guests.join(', ')}</dd>
          </div>
        )}
        {entry.data.coHosts && entry.data.coHosts.length > 0 && (
          <div>
            <dt>Co-host{entry.data.coHosts.length > 1 ? 's' : ''}</dt>
            <dd>{entry.data.coHosts.join(', ')}</dd>
          </div>
        )}
      </dl>

      <div class="press-detail-cta">
        <a href={entry.data.externalUrl} class="press-cta-primary" target="_blank" rel="noopener noreferrer">
          <Icon name="ArrowSquareOut" size={18} weight="bold" />
          {meta.cta} {entry.data.outlet ?? 'original source'}
        </a>
        {entry.data.spotifyUrl && (
          <a href={entry.data.spotifyUrl} class="press-cta-ghost" target="_blank" rel="noopener noreferrer">
            <Icon name="SpotifyLogo" size={18} weight="duotone" />
            Spotify
          </a>
        )}
        {entry.data.appleUrl && (
          <a href={entry.data.appleUrl} class="press-cta-ghost" target="_blank" rel="noopener noreferrer">
            <Icon name="ApplePodcastsLogo" size={18} weight="duotone" />
            Apple Podcasts
          </a>
        )}
        {entry.data.youtubeUrl && (
          <a href={entry.data.youtubeUrl} class="press-cta-ghost" target="_blank" rel="noopener noreferrer">
            <Icon name="YoutubeLogo" size={18} weight="duotone" />
            YouTube
          </a>
        )}
      </div>

      {entry.data.tags && entry.data.tags.length > 0 && (
        <div class="press-detail-tags">
          {entry.data.tags.map(tag => (
            <span class="press-detail-tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {entry.data.coverImage && (
      <div class="press-detail-cover">
        <img src={entry.data.coverImage} alt={entry.data.title} loading="lazy" />
      </div>
    )}

    {entry.data.embedUrl && (
      <div class="press-detail-embed">
        <iframe
          src={entry.data.embedUrl}
          width="100%"
          height="232"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title={entry.data.title}
        ></iframe>
      </div>
    )}

    <div class="press-detail-body prose">
      <Content />
    </div>

    <footer class="press-detail-footer">
      <p class="press-canonical-note">
        <Icon name="LinkSimple" size={14} weight="bold" />
        This is a record of a publication that lives on
        {' '}
        <a href={entry.data.externalUrl} target="_blank" rel="noopener noreferrer">{entry.data.outlet ?? 'an external site'}</a>.
        Visit the original for the full piece.
      </p>
    </footer>

    <RelatedProjects projectSlugs={entry.data.relatedProjects} />
    <RelatedBlogPosts blogSlugs={entry.data.relatedBlogPosts} />
  </article>
</Layout>

<style>
  .press-detail {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .press-detail-header {
    margin-bottom: 2rem;
  }

  .press-detail-type {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: rgba(121, 148, 150, 0.12);
    color: var(--color-tertiary);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  html.dark .press-detail-type {
    background: rgba(233, 235, 158, 0.12);
    color: var(--color-accent);
  }

  .press-detail-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 0.75rem;
    color: var(--text-color);
  }

  html.dark .press-detail-title {
    color: #f3f4f6;
  }

  .press-detail-description {
    font-size: 1.15rem;
    color: var(--text-light);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    max-width: 65ch;
  }

  .press-detail-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem 2rem;
    margin: 0 0 2rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .press-detail-meta div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .press-detail-meta dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-light);
    font-weight: 600;
    margin: 0;
  }

  .press-detail-meta dd {
    font-size: 0.95rem;
    color: var(--text-color);
    margin: 0;
  }

  html.dark .press-detail-meta dd {
    color: #e5e7eb;
  }

  .press-detail-meta a {
    color: var(--color-tertiary);
    text-decoration: none;
  }

  .press-detail-meta a:hover {
    text-decoration: underline;
  }

  html.dark .press-detail-meta a {
    color: var(--color-accent);
  }

  .press-detail-location {
    color: var(--text-light);
  }

  .press-detail-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .press-cta-primary,
  .press-cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.3rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    font-family: var(--font-secondary-header);
  }

  .press-cta-primary {
    background: var(--color-tertiary);
    color: white;
    box-shadow: 0 4px 12px rgba(121, 148, 150, 0.3);
  }

  .press-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(121, 148, 150, 0.4);
  }

  html.dark .press-cta-primary {
    background: var(--color-accent);
    color: #23232b;
  }

  .press-cta-ghost {
    background: transparent;
    color: var(--text-color);
    border: 1px solid var(--border-color);
  }

  .press-cta-ghost:hover {
    border-color: var(--color-tertiary);
    color: var(--color-tertiary);
    transform: translateY(-2px);
  }

  html.dark .press-cta-ghost {
    color: #e5e7eb;
  }

  html.dark .press-cta-ghost:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .press-detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .press-detail-tag {
    background: var(--background-alt);
    padding: 0.2rem 0.7rem;
    border-radius: 4px;
    font-size: 0.8rem;
    color: var(--text-light);
  }

  .press-detail-cover {
    margin: 0 0 2rem;
    border-radius: 12px;
    overflow: hidden;
  }

  .press-detail-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .press-detail-embed {
    margin: 0 0 2rem;
    border-radius: 12px;
    overflow: hidden;
  }

  .press-detail-body {
    margin-bottom: 2.5rem;
  }

  .press-detail-body:empty {
    display: none;
  }

  .press-detail-footer {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
    margin-top: 2rem;
  }

  .press-canonical-note {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    color: var(--text-light);
    font-size: 0.85rem;
    margin: 0;
    font-style: italic;
  }

  .press-canonical-note a {
    color: var(--color-tertiary);
    text-decoration: none;
    font-weight: 600;
  }

  .press-canonical-note a:hover {
    text-decoration: underline;
  }

  html.dark .press-canonical-note a {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .press-detail {
      padding: 1.5rem 1rem 3rem;
    }
    .press-detail-title {
      font-size: 1.75rem;
    }
  }
</style>
