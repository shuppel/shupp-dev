---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Brain Gate" description="Block distractions and build better habits with Brain Gate browser extension. Progressive friction helps you reclaim your focus.">
  <main class="brain-gate-landing">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title">Brain Gate</h1>
        <p class="hero-tagline">Block Distractions. Build Better Habits.</p>
        <p class="hero-description">
          Brain Gate is a browser extension that helps you break free from addictive websites 
          using progressive friction. Instead of hard blocks that you'll just disable, 
          Brain Gate makes distracting sites slightly harder to access, building your 
          self-control muscle over time.
        </p>
        <div class="hero-cta">
          <a href="https://app.thoughtfulapp.co/braingate" class="btn btn-primary btn-large">Get Brain Gate</a>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features">
      <h2>How It Works</h2>
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          </div>
          <h3>Progressive Friction</h3>
          <p>Puzzles, time delays, and typing challenges add just enough friction to break automatic browsing habits.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
          </div>
          <h3>Customizable Categories</h3>
          <p>Block social media, timewaster sites, adult content, or create your own custom categories.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3>Smart Scheduling</h3>
          <p>Set different blocking levels for work hours, evenings, and weekends.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Privacy-First</h3>
          <p>All blocking happens locally. We never see your browsing history or the sites you visit.</p>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing">
      <h2>Simple Pricing</h2>
      <div class="pricing-cards">
        <div class="pricing-card">
          <h3>Monthly</h3>
          <div class="price">$3<span>/mo</span></div>
          <p>Full access to all features</p>
        </div>
        <div class="pricing-card featured">
          <div class="featured-badge">Best Value</div>
          <h3>Yearly</h3>
          <div class="price">$28<span>/yr</span></div>
          <p>Save 22% with annual billing</p>
        </div>
        <div class="pricing-card">
          <h3>TACo Club</h3>
          <div class="price">FREE</div>
          <p>Included with TACo Club or Lifetime membership</p>
        </div>
      </div>
    </section>

    <!-- Download Section -->
    <section class="download">
      <h2>Download Brain Gate</h2>
      <p class="download-description">Available for Chrome and Firefox. Get started in seconds.</p>
      <div class="download-buttons">
        <a href="#" class="download-btn chrome">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0 1 12 6.545h10.691A12 12 0 0 0 12 0zM1.931 5.47A11.943 11.943 0 0 0 0 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 0 1-6.865-2.29zm13.342 2.166a5.446 5.446 0 0 1 1.45 7.09l.002.001h-.002l-3.952 6.848a12.014 12.014 0 0 0 9.297-9.076H15.273z"/></svg>
          Chrome Web Store
          <span class="coming-soon">Coming Soon</span>
        </a>
        <a href="#" class="download-btn firefox">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 5.468c.124.089.227.195.305.315.234.362.297.82.164 1.247-.132.426-.432.77-.82.942-.388.171-.838.171-1.226 0-.388-.172-.688-.516-.82-.942-.133-.427-.07-.885.164-1.247.234-.362.577-.596.973-.656.396-.06.8.06 1.102.314.048.04.093.083.158.027zm-8.788.54c.396-.06.8.06 1.102.315.124.089.227.195.305.315.234.362.297.82.164 1.247-.132.426-.432.77-.82.942-.388.171-.838.171-1.226 0-.388-.172-.688-.516-.82-.942-.133-.427-.07-.885.164-1.247.234-.362.577-.596.973-.656.048-.007.11.02.158.026z"/></svg>
          Firefox Add-ons
          <span class="coming-soon">Coming Soon</span>
        </a>
      </div>
      <p class="download-note">
        Or manage your account and subscription at<br>
        <a href="https://app.thoughtfulapp.co/braingate">app.thoughtfulapp.co/braingate</a>
      </p>
    </section>

    <!-- Footer Links -->
    <section class="page-footer">
      <a href="/brain-gate/privacy">Privacy Policy</a>
    </section>
  </main>
</Layout>

<style>
  .brain-gate-landing {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
  }

  /* Hero Section */
  .hero {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #D84727 0%, #FFB30F 100%);
    border-radius: 16px;
    margin-bottom: 4rem;
    color: white;
  }

  .hero-title {
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
    color: white;
  }

  .hero-tagline {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    opacity: 0.95;
  }

  .hero-description {
    font-size: 1.125rem;
    max-width: 700px;
    margin: 0 auto 2rem;
    line-height: 1.7;
    opacity: 0.9;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-large {
    padding: 0.875rem 2rem;
    font-size: 1.125rem;
  }

  .hero .btn-primary {
    background: white;
    color: #D84727;
  }

  .hero .btn-primary:hover {
    background: #0D0F0D;
    color: white;
  }

  /* Features Section */
  .features {
    padding: 2rem;
    margin-bottom: 4rem;
  }

  .features h2 {
    text-align: center;
    margin-bottom: 3rem;
    font-size: 2.5rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
    box-shadow: var(--card-shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .feature-icon {
    color: #D84727;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--text-color);
  }

  .feature-card p {
    color: var(--text-light);
    line-height: 1.6;
    margin: 0;
  }

  /* Pricing Section */
  .pricing {
    padding: 2rem;
    margin-bottom: 4rem;
    text-align: center;
  }

  .pricing h2 {
    margin-bottom: 3rem;
    font-size: 2.5rem;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-card {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: var(--card-shadow);
    position: relative;
  }

  .pricing-card.featured {
    border: 3px solid #1D9E5C;
    transform: scale(1.05);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #1D9E5C;
    color: white;
    padding: 0.25rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .pricing-card h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: var(--text-color);
  }

  .price {
    font-size: 2.5rem;
    font-weight: 700;
    color: #D84727;
    margin-bottom: 0.5rem;
  }

  .price span {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-light);
  }

  .pricing-card p {
    color: var(--text-light);
    margin: 0;
  }

  /* Download Section */
  .download {
    padding: 3rem 2rem;
    text-align: center;
    background: var(--card-bg);
    border-radius: 16px;
    margin-bottom: 2rem;
  }

  .download h2 {
    margin-bottom: 1rem;
    font-size: 2rem;
  }

  .download-description {
    color: var(--text-light);
    margin-bottom: 2rem;
  }

  .download-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
  }

  .download-btn.chrome {
    background: #0D0F0D;
    color: white;
  }

  .download-btn.chrome:hover {
    background: #D84727;
  }

  .download-btn.firefox {
    background: #FF7139;
    color: white;
  }

  .download-btn.firefox:hover {
    background: #E65100;
  }

  .coming-soon {
    font-size: 0.7rem;
    background: rgba(255, 255, 255, 0.2);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .download-note {
    color: var(--text-light);
    font-size: 0.95rem;
  }

  .download-note a {
    color: #D84727;
    font-weight: 600;
  }

  .download-note a:hover {
    text-decoration: underline;
  }

  /* Page Footer */
  .page-footer {
    text-align: center;
    padding: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .page-footer a {
    color: var(--text-light);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .page-footer a:hover {
    color: #D84727;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.5rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-tagline {
      font-size: 1.25rem;
    }

    .pricing-card.featured {
      transform: none;
    }

    .download-buttons {
      flex-direction: column;
      align-items: center;
    }

    .download-btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }

  /* Dark mode adjustments */
  :global(html.dark) .feature-icon {
    color: #FFB30F;
  }

  :global(html.dark) .price {
    color: #FFB30F;
  }

  :global(html.dark) .pricing-card.featured {
    border-color: #1D9E5C;
  }

  :global(html.dark) .download-note a {
    color: #FFB30F;
  }

  :global(html.dark) .page-footer a:hover {
    color: #FFB30F;
  }
</style>
