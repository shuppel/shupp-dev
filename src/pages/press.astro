---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon/Icon.astro';

const allPress = await getCollection('press');

// Sort by date descending
const items = allPress.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// Group items by year
const itemsByYear = items.reduce((acc, item) => {
  const year = new Date(item.data.pubDate).getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(item);
  return acc;
}, {} as Record<number, typeof items>);

// Get years sorted descending
const years = Object.keys(itemsByYear).map(Number).sort((a, b) => b - a);

const TYPE_META: Record<string, { label: string; icon: string }> = {
  'article':         { label: 'Article',         icon: 'Article' },
  'podcast-episode': { label: 'Podcast',         icon: 'Microphone' },
  'podcast-guest':   { label: 'Guest',           icon: 'MicrophoneStage' },
  'talk':            { label: 'Talk',            icon: 'Presentation' },
  'interview':       { label: 'Interview',       icon: 'ChatsCircle' },
  'mention':         { label: 'Mention',         icon: 'Quotes' },
  'award':           { label: 'Award',           icon: 'Trophy' },
  'video':           { label: 'Video',           icon: 'PlayCircle' },
};

// Helper to get favicon URL from outlet
function getFaviconUrl(url: string | undefined): string {
  if (!url) return '';
  try {
    const domain = new URL(url).hostname;
    return `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
  } catch {
    return '';
  }
}

// Helper to get display URL
function getDisplayUrl(url: string | undefined): string {
  if (!url) return '';
  try {
    const domain = new URL(url).hostname.replace(/^www\./, '');
    return domain;
  } catch {
    return '';
  }
}
---

<Layout
  title="Press"
  description="Articles, podcast episodes, talks, interviews, and other public appearances by Erikk Shupp."
>
  <div class="press-layout">
    <!-- Left sidebar with years -->
    <aside class="press-sidebar">
      <nav class="year-nav" aria-label="Filter by year">
        <ul class="year-list">
          <li>
            <a href="#all" class="year-link is-active" data-year="all" aria-current="page">
              All
              <span class="year-count">{items.length}</span>
            </a>
          </li>
          {years.map(year => (
            <li>
              <a href={`#${year}`} class="year-link" data-year={year}>
                {year}
                <span class="year-count">{itemsByYear[year].length}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="press-content">
      <header class="press-header-section">
        <h1>Press</h1>
        <p class="press-subtitle">Articles, podcasts, talks, and interviews</p>
      </header>

      {years.map(year => (
        <section class="year-section" id={String(year)} data-year={year}>
          <h2 class="year-heading">{year}</h2>
          <ul class="appearance-list">
            {itemsByYear[year].map(item => {
              const meta = TYPE_META[item.data.type];
              const favicon = getFaviconUrl(item.data.externalUrl);
              const displayUrl = getDisplayUrl(item.data.externalUrl);
              const date = new Date(item.data.pubDate).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
              });
              return (
                <li class="appearance-item">
                  <a href={`/press/${item.id}`} class="appearance-link">
                    <div class="appearance-preview">
                      {item.data.coverImage ? (
                        <img src={item.data.coverImage} alt="" class="appearance-thumbnail" loading="lazy" />
                      ) : favicon ? (
                        <img src={favicon} alt="" class="appearance-favicon" loading="lazy" />
                      ) : (
                        <div class="appearance-icon-fallback">
                          <Icon name={meta?.icon ?? 'Bookmark'} size={20} weight="duotone" />
                        </div>
                      )}
                    </div>
                    <div class="appearance-body">
                      <div class="appearance-meta-row">
                        <span class="appearance-type">{meta?.label ?? item.data.type}</span>
                        <span class="appearance-date">{date}</span>
                      </div>
                      <h3 class="appearance-title">{item.data.title}</h3>
                      <p class="appearance-description">{item.data.description}</p>
                      <div class="appearance-outlet">
                        <Icon name="Globe" size={12} weight="duotone" />
                        <span>{item.data.outlet ?? displayUrl}</span>
                      </div>
                    </div>
                    <div class="appearance-arrow">
                      <Icon name="ArrowRight" size={20} weight="duotone" />
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </main>
  </div>
</Layout>

<script>
  // Year navigation highlighting
  document.addEventListener('astro:page-load', () => {
    const yearLinks = document.querySelectorAll<HTMLAnchorElement>('.year-link');
    const sections = document.querySelectorAll<HTMLElement>('.year-section');
    
    // Click handling for year links
    yearLinks.forEach(link => {
      link.addEventListener('click', () => {
        const year = link.dataset.year;
        
        // Update active state
        yearLinks.forEach(l => l.classList.remove('is-active'));
        link.classList.add('is-active');
        
        // Show/hide sections
        if (year === 'all') {
          sections.forEach(s => s.removeAttribute('hidden'));
        } else {
          sections.forEach(s => {
            if (s.dataset.year === year) {
              s.removeAttribute('hidden');
            } else {
              s.setAttribute('hidden', '');
            }
          });
        }
      });
    });

    // Scroll spy to update active year
    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -80% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const year = entry.target.getAttribute('id');
          yearLinks.forEach(link => {
            const active = link.getAttribute('href') === `#${year}`;
            link.classList.toggle('is-active', active);
            if (active) {
              link.setAttribute('aria-current', 'page');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        }
      });
    }, observerOptions);

    sections.forEach(section => observer.observe(section));
  });
</script>

