# Feature Flags
# Enable TLDraw mockup embeds (default: false)
ENABLE_TLDRAW=false

# Screenshot Machine API
SCREENSHOT_MACHINE_API_KEY=your_api_key_here

# Spotify Podcast RSS Feed
# Get this from your Spotify for Podcasters dashboard
# Format: https://anchor.fm/s/XXXXXX/podcast/rss
SPOTIFY_RSS_URL=